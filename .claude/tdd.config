# Test command per layer. Sourced by .claude/hooks/run-suite.sh.
# Keep these in sync with the scripts in package.json. Swapping a layer's stack
# (e.g. a Python backend) means editing only the relevant line here.
BE_TEST_CMD="pnpm test:backend"
FE_TEST_CMD="pnpm test:frontend"
E2E_TEST_CMD="pnpm test:e2e"
