# ─── TDD pairing config — Based prototype (0.3.0 format) ──────────
# Sourced by every hook. Defines the project's test "layers". The orchestrator
# writes the active layer to .claude/state/layer before each cycle; the hooks
# use the matching command + globs (via resolve_layer). This file is YOURS — the
# installer seeds it once and never overwrites it.

LAYERS="backend frontend e2e"

# Full-suite gate: final "done" check, fallback command, SessionStart baseline.
ALL_TEST_CMD="pnpm verify"

DEFAULT_TEST_GLOB='(\.test\.|\.spec\.|(^|/)tests?/|(^|/)__tests__/)'
DEFAULT_SRC_GLOB='(^|/)src/'

# ── Per-layer (commands match package.json scripts) ───────────────
TEST_CMD_backend="pnpm test:backend"
TEST_GLOB_backend='(^|/)backend/.*(\.test\.ts|\.spec\.ts)$'
SRC_GLOB_backend='(^|/)backend/src/.*\.ts$'

# frontend: logic tests .test.ts, component tests .test.tsx (vite glob {ts,tsx}).
TEST_CMD_frontend="pnpm test:frontend"
TEST_GLOB_frontend='(^|/)frontend/.*(\.test\.tsx?|\.spec\.tsx?)$'
SRC_GLOB_frontend='(^|/)frontend/src/.*\.(ts|tsx)$'

TEST_CMD_e2e="pnpm test:e2e"
TEST_GLOB_e2e='(^|/)e2e/.*\.spec\.ts$'
SRC_GLOB_e2e='(^|/)e2e/.*\.ts$'

TAIL_LINES=40

# ── SessionStart baseline check (warn, not block) ─────────────────
: "${SESSION_BASELINE_CHECK:=1}"
: "${BASELINE_CMD:=$ALL_TEST_CMD}"

# ── Cycle telemetry → .claude/state/telemetry.jsonl (gitignored) ──
: "${TELEMETRY:=1}"

# ── Resolver (bash 3.2 safe) ──────────────────────────────────────
resolve_layer() {
  _l="$1"
  eval "TEST_CMD=\"\${TEST_CMD_${_l}:-}\""
  eval "TEST_GLOB=\"\${TEST_GLOB_${_l}:-}\""
  eval "SRC_GLOB=\"\${SRC_GLOB_${_l}:-}\""
  [ -n "$TEST_CMD" ]  || TEST_CMD="$ALL_TEST_CMD"
  [ -n "$TEST_GLOB" ] || TEST_GLOB="$DEFAULT_TEST_GLOB"
  [ -n "$SRC_GLOB" ]  || SRC_GLOB="$DEFAULT_SRC_GLOB"
}
