# Backend environment — copy to backend/.env for local dev. NEVER commit backend/.env.
# In AWS staging these are delivered by App Runner: CORS_ORIGINS/GEMINI_MODEL as env vars,
# GEMINI_API_KEY as a RuntimeEnvironmentSecret from SSM Parameter Store (see infra/).

# Gemini narration (M3): POST /narrate voices a PerceptionEvent into one spoiler-safe line.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash

# CORS allowlist — comma-separated origins permitted to call this API.
CORS_ORIGINS=http://localhost:5173

# Local server port (App Runner overrides to 8080).
PORT=3000
